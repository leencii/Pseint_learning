Algoritmo Nota_estudiante
	Definir nota Como Entero
	Definir estudiante Como Caracter
	
	Escribir "Ingrese su nombre:"
	Leer estudiante
	Escribir "Ingrese su nota en el examen:"
	Leer nota
	
	Si nota>=6 Entonces
		Escribir estudiante ", usted esta aprobado"
	SiNo
		Escribir estudiante ", usted esta desaprobado"
	FinSi
	
FinAlgoritmo
