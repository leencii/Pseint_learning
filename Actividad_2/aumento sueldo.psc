Algoritmo Aumento_sueldo
	
	Definir peso_arg, dolar, conversion Como Real
	Escribir "dime la cantidad de pesos que quieres cambiar:"
	Leer peso_arg
	Escribir "ahora dime el valor del dolar el dia de hoy:"
	Leer dolar
	conversion<-(peso_arg/dolar)
	Escribir "el cambio al dia de hoy es de:", conversion
	
	
	
FinAlgoritmo