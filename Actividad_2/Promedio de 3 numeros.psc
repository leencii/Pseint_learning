Algoritmo promedio_de_numeros
	
	Definir numero1 Como Entero
	Definir numero2 Como Entero
	Definir numero3 Como Entero
	Escribir "dime un numero:"
	Leer numero1
	Escribir "ahora dime otro:"
    Leer numero2
	Escribir "ahora dime un ultimo numero:"
	Leer numero3
	Escribir "el promedio de ", numero1,  " con " numero2 " y " numero3 " es: " (numero1+numero2+numero3)/3
	
FinAlgoritmo
