Algoritmo porcentaje_dinero
	Definir dinero, porcentaje1, porcentaje2, total1, total2 Como Real
	Escribir "Ingrese un porcentaje a programar:"
	Leer dinero
	porcentaje1<-(dinero*10)/100
	porcentaje2<-(dinero*25)/100
	total1<-(porcentaje1*10)/100
	total2<-(porcentaje2*10)/100
	Escribir "El 10% del valor ingresado es: ", porcentaje1 ", el 25% del valor es: ", porcentaje2 " y si se le suma un 10% al resultado de cada uno quedan en: ", total1 " y ", total2
	
	
	
	
FinAlgoritmo
