Algoritmo dos_numeros
	Definir num1, num2, suma, doblesuma, mitad Como Real
	Escribir "deme un numero:"
	Leer num1
	Escribir "deme otro numero:"
	Leer num2
	suma<-num1+num2
	doblesuma<-suma*2
	mitad<-num1/2
	Escribir "la suma de los dos numeros es: ", suma ", el doble de la suma es: ", doblesuma " y por ultimo la mitad del primer numero es: ", mitad
	
FinAlgoritmo