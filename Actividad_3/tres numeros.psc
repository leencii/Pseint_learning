Algoritmo tres_numeros
	Definir num1, num2, num3, Suma, promedio, mult Como Real
	Escribir "dime un numero:"
	Leer num1
	Escribir "dime otro:"
	Leer num2
	Escribir "dime un ultimo numero:"
	Leer num3
	Suma<-num1+num2+num3
	promedio<-Suma/3
	mult<-num1*num3
	Escribir "la suma de los numeros es: ", Suma " el promedio es: ", promedio " y la multiplicacion entre el primero y el ultimo es: ", mult
	
	
	
FinAlgoritmo