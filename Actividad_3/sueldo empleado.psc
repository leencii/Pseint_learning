Algoritmo sueldo_empleado
	Definir nombre Como Caracter
	Definir sueldo_basico, bono, sueldo_final Como Real
	Escribir "Bienvenido! Ingrese su nombre:"
	Leer nombre
	Escribir "Ingrese su sueldo basico:"
	Leer sueldo_basico
	Escribir "Por ultimo ingrese su bono fijo:"
	Leer bono
	sueldo_final<-sueldo_basico+bono
	Escribir nombre ", su sueldo final es de: " sueldo_final
	
FinAlgoritmo