Algoritmo dias_semana
	Definir num Como Entero
	Escribir "ingrese un numero del 1 al 7:"
	Leer num
	
	Segun num Hacer
		Opcion 1:
			Escribir "Lunes"
		Opcion 2:
			Escribir "Martes"
		Opcion 3:
			Escribir "Miercoles"
		Opcion 4:
			Escribir "Jueves"
		Opcion 5:
			Escribir "Viernes"
		Opcion 6:
			Escribir "Sabado"
		Opcion 7:
			Escribir "Domingo"
	FinSegun
	
FinAlgoritmo
